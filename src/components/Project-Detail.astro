---
/**
 * @param {string} title プロジェクト名
 * @param {string} join_date プロジェクト参画日
 * @param {string} description プロジェクト詳細
 */
const { title, join_date, description } = Astro.props;
---

<div class="flex flex-row gap-3 pl-2 group">
  <div class="flex flex-col items-center w-5 shrink-0">
    <div class="flex flex-col items-center flex-1">
      <div class="flex-1 w-px bg-red-700/60"></div>
      <div
        class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0
              shadow-[0_0_8px_rgba(239,68,68,0.8)] z-0"
      >
        <div class="w-8 h-px bg-red-700/50 mt-1 ml-2.5"></div>
      </div>
      <div class="flex-1 w-px bg-red-700/60"></div>
    </div>
  </div>

  <!-- プロジェクトカード -->
  <div
    class="flex-1 m-4 p-4 rounded-xl
           bg-white/5 border border-white/10
           backdrop-blur-sm
           shadow-[0_2px_16px_rgba(0,0,0,0.3)]
           transition-all duration-300 ease-out
           hover:bg-white/8 hover:border-red-800/40
           hover:shadow-[0_4px_24px_rgba(239,68,68,0.12)]
           hover:-translate-y-0.5"
  >
    <p
      class="font-semibold text-base text-gray-100 leading-snug mb-1.5
             group-hover:text-red-300 transition-colors duration-200"
    >
      {title}
      <span class="block sm:inline sm:ml-5 text-sm text-gray-400 mt-1 sm:mt-0"
        >{join_date}</span
      >
    </p>
    <div class="h-px w-full bg-linear-to-r from-red-800/40 to-transparent mb-2">
    </div>
    <p class="text-sm text-gray-400 leading-relaxed">
      {description}
    </p>
  </div>
</div>
