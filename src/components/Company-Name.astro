---
/**
 * @param {string} name 会社名
 * @param {string} join_date 入社日
 * @param {string} terminate_data 退社日
 * @param {string} url 会社URL
 */
const { name, join_date, terminate_data, url } = Astro.props;
---

<div class="relative flex items-center gap-4 py-3">
  <!-- アクセントバー -->
  <div
    class="absolute left-0 top-0 h-full w-1 rounded-full bg-linear-to-b from-red-500 to-red-800 shadow-[0_0_8px_rgba(239,68,68,0.6)]"
  >
  </div>

  <div class="pl-5 flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
    <!-- 会社名 -->
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xl font-bold bg-linear-to-r from-white to-gray-300 bg-clip-text text-transparent tracking-tight"
    >
      {name}
    </a>

    <!-- 在籍期間バッジ -->
    <span
      class="inline-flex w-auto items-center justify-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium
                 bg-red-950/50 border border-red-800/50 text-red-300
                 shadow-[0_0_6px_rgba(239,68,68,0.2)]"
    >
      <span class="w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse"></span>
      {join_date} &nbsp;–&nbsp; {terminate_data}
    </span>
  </div>
</div>
